{
  "name": "anti-compact",
  "description": "Intercepts /compact and generates a structured session handoff instead of lossy compaction",
  "author": { "name": "Joe Black", "email": "joeblackwaslike@gmail.com" },
  "homepage": "https://github.com/joeblackwaslike/anti-compact",
  "repository": "https://github.com/joeblackwaslike/anti-compact",
  "license": "MIT",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/precompact-handoff.mjs\"",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "commands": [
    {
      "name": "handoff",
      "description": "Generate a structured session handoff, or manage precompact automation (auto/on/off)",
      "file": "commands/handoff.md"
    }
  ]
}
